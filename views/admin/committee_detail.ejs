<%- include('../partials/head', { pageTitle: committee.name }) %>
<%- include('../partials/admin_nav') %>

<main class="max-w-7xl mx-auto px-6 py-8">
  <a href="/admin" class="text-sm text-slate-500 hover:text-slate-900">← 대시보드</a>

  <% if (locals.fromNewMeeting) { %>
  <div class="mt-3 bg-amber-50 border border-amber-300 text-amber-900 rounded-lg p-4 flex items-center justify-between">
    <div class="text-sm">
      💾 회의 작성을 잠시 멈추고 위원 명단을 수정중입니다. 작성내용은 자동 저장되어 있습니다.
    </div>
    <a href="/admin/committees/<%= committee.id %>/meetings/new" class="bg-amber-600 hover:bg-amber-700 text-white text-sm font-semibold px-4 py-2 rounded-lg">← 회의 작성 페이지로 돌아가기</a>
  </div>
  <% } %>
  <div class="flex items-start justify-between mt-2 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= committee.name %></h1>
      <% if (committee.description) { %><p class="text-sm text-slate-500 mt-1"><%= committee.description %></p><% } %>
    </div>
    <a href="/admin/committees/<%= committee.id %>/meetings/new" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-semibold">+ 새 회의 일정 잡기</a>
  </div>

  <%
    const TYPE_LABEL = { faculty: '교원', staff: '직원', student: '학생', external: '외부 위원' };
    const TYPE_BADGE = { faculty: 'badge-blue', staff: 'badge-amber', student: 'badge-green', external: 'badge-violet' };
  %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-bold text-slate-900">위원 명단 (<%= members.length %>)</h2>
        <span class="text-xs text-slate-400">🤖 교원 추가 시 한성대 시간표 자동 연결</span>
      </div>

      <% if (locals.errFlag === 'name-email-required') { %>
      <div class="mb-4 bg-red-50 border border-red-300 text-red-800 rounded-lg px-3 py-2 text-sm">
        ⚠️ 이름과 이메일은 필수 입력 항목입니다.
      </div>
      <% } %>

      <% if (locals.memberAddIssue) { %>
      <div class="mb-4 bg-indigo-50 border border-indigo-300 text-indigo-900 rounded-lg px-3 py-3 text-sm">
        📨 <strong><%= memberAddIssue.memberName %></strong> 위원에게 진행중인 회의 <strong><%= memberAddIssue.meetings.length %>건</strong>의 응답 링크가 자동 발급됐어요.
        <ul class="mt-1 text-xs text-indigo-800 list-disc pl-5">
          <% memberAddIssue.meetings.forEach(m => { %><li><a class="underline" href="/admin/meetings/<%= m.meetingId %>">#<%= m.meetingId %> <%= m.title %></a></li><% }) %>
        </ul>
      </div>
      <% } %>

      <% if (locals.autoCrawl) { %>
        <% if (autoCrawl.error) { %>
        <div class="mb-4 bg-amber-50 border border-amber-300 text-amber-900 rounded-lg px-3 py-3 text-sm">
          ⚠️ <strong><%= autoCrawl.name %></strong> 교원 추가됨. 시간표 자동 연결 실패: <code class="text-xs"><%= autoCrawl.error %></code>
        </div>
        <% } else if ((autoCrawl.matchedMajors || []).length === 0) { %>
        <div class="mb-4 bg-slate-50 border border-slate-300 text-slate-700 rounded-lg px-3 py-3 text-sm">
          ℹ️ <strong><%= autoCrawl.name %></strong> 교원 추가됨. <%= autoCrawl.yearhakgi %> 학기 한성대 OC 시간표에 동일 이름 강의 없음.
        </div>
        <% } else { %>
        <div class="mb-4 bg-emerald-50 border border-emerald-300 text-emerald-900 rounded-lg px-3 py-3 text-sm">
          ✅ <strong><%= autoCrawl.name %></strong> 교원 추가 + 시간표 자동 연결 완료
          (<%= autoCrawl.yearhakgi.slice(0,4) %>-<%= autoCrawl.yearhakgi.slice(4) %>학기, 강의 <%= autoCrawl.classCount %>건, 슬롯 <%= autoCrawl.slotCount %>개)
          <% if (autoCrawl.matchedMajors.length > 1) { %>
            <div class="mt-2 text-xs">
              🔀 여러 학과에서 동일 이름 매칭 (자동 병합):
              <% autoCrawl.matchedMajors.forEach((mm,i)=>{ %>
                <span class="inline-block bg-white border border-emerald-400 text-emerald-800 rounded px-2 py-0.5 mr-1"><%= mm.name %> (<%= mm.classCount %>건)</span>
              <% }) %>
              <div class="mt-1 text-slate-600">→ 동명이인이면 위원 카드의 [시간표] 버튼에서 해당 강의 삭제 가능</div>
            </div>
          <% } else { %>
            <div class="mt-1 text-xs text-emerald-800">출처: <%= autoCrawl.matchedMajors[0].name %></div>
          <% } %>
        </div>
        <% } %>
      <% } %>

      <% if (members.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-xs text-slate-500 border-b">
            <tr><th class="py-2 text-left">이름</th><th class="text-left">구분</th><th class="text-left">소속/역할</th><th class="text-left">연락처</th><th></th></tr>
          </thead>
          <tbody>
            <% members.forEach(m => { %>
              <% let ttCount = 0; if (m.timetable_cache) { try { ttCount = (JSON.parse(m.timetable_cache)||[]).length; } catch(e){} } %>
              <% let ttMeta = null; if (m.timetable_meta) { try { ttMeta = JSON.parse(m.timetable_meta); } catch(e){} } %>
              <% const multiMajor = ttMeta && (ttMeta.matchedMajors||[]).length > 1; %>
              <tr class="border-b last:border-b-0">
                <td class="py-2 font-medium"><%= m.name %><% if (m.sabun) { %><span class="text-xs text-slate-400 ml-1">#<%= m.sabun %></span><% } %></td>
                <td><span class="badge <%= TYPE_BADGE[m.type] || 'badge-violet' %>"><%= TYPE_LABEL[m.type] || m.type %></span></td>
                <td class="text-slate-600 text-xs"><%= [m.affiliation, m.role].filter(Boolean).join(' / ') %></td>
                <td class="text-slate-600 text-xs"><%= m.email || m.phone || '-' %></td>
                <td>
                  <div class="flex items-center gap-2">
                    <a href="/admin/committees/<%= committee.id %>/members/<%= m.id %>/timetable"
                       class="text-xs border rounded px-2 py-1 hover:bg-slate-50 whitespace-nowrap">
                      📅 시간표<% if (ttCount > 0) { %> <span class="badge badge-green ml-0.5"><%= ttCount %></span><% } %>
                      <% if (multiMajor) { %><span class="badge badge-amber ml-0.5" title="여러 학과에서 동일 이름 매칭">🔀<%= ttMeta.matchedMajors.length %></span><% } %>
                    </a>
                    <form method="POST" action="/admin/committees/<%= committee.id %>/members/<%= m.id %>/delete" onsubmit="return confirm('삭제하시겠습니까?')">
                      <button class="text-xs text-red-500 hover:underline">삭제</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p class="text-sm text-slate-500 py-4 text-center">아직 등록된 위원이 없습니다. 아래에서 추가해주세요.</p>
      <% } %>

      <div class="mt-4 border-t pt-4">
        <div class="text-sm font-semibold text-slate-700 mb-1">+ 위원 추가</div>
        <div class="text-xs text-slate-500 mb-3">교원으로 추가하면 한성대 OC 시간표에서 동일 이름 강의를 자동으로 가져옵니다 (1-2초 소요).</div>
        <form method="POST" action="/admin/committees/<%= committee.id %>/members" class="grid grid-cols-2 gap-3">
          <div class="col-span-2 grid grid-cols-4 gap-2">
            <label class="flex items-center gap-1.5 border rounded-lg px-2 py-2 cursor-pointer has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-400">
              <input type="radio" name="type" value="faculty" checked> <span class="text-xs">교원</span>
            </label>
            <label class="flex items-center gap-1.5 border rounded-lg px-2 py-2 cursor-pointer has-[:checked]:bg-amber-50 has-[:checked]:border-amber-400">
              <input type="radio" name="type" value="staff"> <span class="text-xs">직원</span>
            </label>
            <label class="flex items-center gap-1.5 border rounded-lg px-2 py-2 cursor-pointer has-[:checked]:bg-emerald-50 has-[:checked]:border-emerald-400">
              <input type="radio" name="type" value="student"> <span class="text-xs">학생</span>
            </label>
            <label class="flex items-center gap-1.5 border rounded-lg px-2 py-2 cursor-pointer has-[:checked]:bg-violet-50 has-[:checked]:border-violet-400">
              <input type="radio" name="type" value="external"> <span class="text-xs">외부위원</span>
            </label>
          </div>
          <input name="name" placeholder="이름 *" required class="border rounded-lg px-3 py-2 text-sm">
          <input name="email" type="email" placeholder="이메일 *" required class="border rounded-lg px-3 py-2 text-sm">
          <input name="role" placeholder="역할 (선택)" class="border rounded-lg px-3 py-2 text-sm">
          <input name="affiliation" placeholder="소속 (선택)" class="border rounded-lg px-3 py-2 text-sm">
          <input name="sabun" placeholder="사번 (선택)" class="border rounded-lg px-3 py-2 text-sm">
          <input name="phone" placeholder="전화번호 (선택)" class="border rounded-lg px-3 py-2 text-sm">
          <button class="col-span-2 bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 rounded-lg text-sm font-semibold">+ 위원 추가 (교원은 시간표 자동 연결)</button>
        </form>
      </div>
    </div>

    <div class="bg-white border rounded-xl p-5">
      <h2 class="font-bold text-slate-900 mb-3">회의 이력 (<%= meetings.length %>)</h2>
      <% if (meetings.length === 0) { %>
        <p class="text-sm text-slate-500 py-4 text-center">아직 등록된 회의가 없습니다.</p>
      <% } %>
      <div class="space-y-2">
        <% meetings.forEach(m => { %>
          <a href="/admin/meetings/<%= m.id %>" class="block border rounded-lg px-4 py-3 hover:border-indigo-400">
            <div class="flex items-center justify-between">
              <div class="font-medium text-sm"><%= m.title %></div>
              <% if (m.status === 'scheduling') { %><span class="badge badge-amber">조율중</span>
              <% } else if (m.status === 'confirmed') { %><span class="badge badge-blue">확정</span>
              <% } else if (m.status === 'completed') { %><span class="badge badge-green">완료</span>
              <% } %>
            </div>
            <div class="text-xs text-slate-500 mt-1">
              후보 일정 <%= m.slot_count %>개 · 응답 <%= m.responded_count %>/<%= members.length %>명
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
</main>
</body></html>
