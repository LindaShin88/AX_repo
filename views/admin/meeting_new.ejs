<%- include('../partials/head', { pageTitle: '새 회의 일정' }) %>
<%- include('../partials/admin_nav') %>

<main class="max-w-3xl mx-auto px-6 py-8">
  <div class="flex items-center justify-between mb-2">
    <a href="/admin/committees/<%= committee.id %>" class="text-sm text-slate-500 hover:text-slate-900">← <%= committee.name %></a>
    <button type="button" onclick="goEditMembers()" class="text-sm border bg-white hover:bg-slate-50 rounded-lg px-3 py-1.5">
      👥 위원 명단 수정하기 (작성내용 유지)
    </button>
  </div>
  <h1 class="text-2xl font-bold text-slate-900 mb-2">새 회의 일정 잡기</h1>
  <p class="text-sm text-slate-500 mb-6">조건을 입력하면 시스템이 후보 일정을 자동 생성하고, 위원들에게 응답 링크를 발송합니다.</p>

  <div id="restored-banner" class="hidden bg-amber-50 border border-amber-300 text-amber-900 text-sm rounded-lg p-3 mb-4">
    💾 이전에 작성하던 회의 정보가 자동으로 복원되었습니다.
    <button type="button" onclick="clearDraft(true)" class="ml-2 underline text-amber-700">초기화</button>
  </div>

  <form id="meeting-form" method="POST" action="/admin/committees/<%= committee.id %>/meetings" class="space-y-5" autocomplete="off">

    <section class="bg-white border rounded-xl p-6 space-y-4">
      <h2 class="font-bold text-slate-900">1. 기본 정보</h2>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">회의명 <span class="text-red-500">*</span></label>
        <input name="title" required class="w-full border rounded-lg px-3 py-2" placeholder="예: 2026-1학기 정기회의">
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">회의 장소</label>
          <input name="location" class="w-full border rounded-lg px-3 py-2" placeholder="예: 본관 회의실 301">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">회의 시간 (분)</label>
          <select name="duration_minutes" class="w-full border rounded-lg px-3 py-2">
            <option value="30">30분</option>
            <option value="60" selected>60분</option>
            <option value="90">90분</option>
            <option value="120">120분</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">안건 / 회의 안내사항</label>
        <textarea name="description" rows="2" class="w-full border rounded-lg px-3 py-2" placeholder="안건, 사전 검토 자료, 기타 안내"></textarea>
      </div>
    </section>

    <section class="bg-white border rounded-xl p-6 space-y-4">
      <h2 class="font-bold text-slate-900">2. 가능 일정 조건</h2>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">날짜 범위 - 시작</label>
          <input type="date" name="window_start" required value="<%= defaults.window.start %>" class="w-full border rounded-lg px-3 py-2">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">날짜 범위 - 종료</label>
          <input type="date" name="window_end" required value="<%= defaults.window.end %>" class="w-full border rounded-lg px-3 py-2">
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">제외 날짜 (콤마 또는 줄바꿈)</label>
        <input name="excluded_dates" class="w-full border rounded-lg px-3 py-2" placeholder="2026-05-22, 2026.5.25, 2026/5/27">
        <p class="text-xs text-slate-500 mt-1">전체 불가능한 날짜를 입력합니다. <code class="bg-slate-100 px-1 rounded">2026-05-22</code>, <code class="bg-slate-100 px-1 rounded">2026.5.22</code>, <code class="bg-slate-100 px-1 rounded">2026/5/22</code>, <code class="bg-slate-100 px-1 rounded">2026.5.22.</code> 다 자동 인식됨.</p>
      </div>

      <%
        const MORNING_PRESETS = ['9:00','9:30','10:00','10:30','11:00','11:30'];
        const AFTERNOON_PRESETS = ['13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30'];
      %>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">가능한 시작 시간 <span class="text-xs text-slate-400 font-normal">(아무것도 안 고르면 10:00, 14:00, 15:00 기본 적용)</span></label>

        <div class="flex flex-wrap gap-1.5 mb-2">
          <button type="button" onclick="applyTimePreset('work')" class="text-xs border border-indigo-200 bg-indigo-50 hover:bg-indigo-100 text-indigo-900 rounded-lg px-3 py-1.5 font-semibold">⏰ 업무시간 (10-16시)</button>
          <button type="button" onclick="applyTimePreset('morning')" class="text-xs border border-amber-200 bg-amber-50 hover:bg-amber-100 text-amber-900 rounded-lg px-3 py-1.5 font-semibold">🌅 오전만</button>
          <button type="button" onclick="applyTimePreset('afternoon')" class="text-xs border border-orange-200 bg-orange-50 hover:bg-orange-100 text-orange-900 rounded-lg px-3 py-1.5 font-semibold">🌇 오후만</button>
          <button type="button" onclick="applyTimePreset('allday')" class="text-xs border border-emerald-200 bg-emerald-50 hover:bg-emerald-100 text-emerald-900 rounded-lg px-3 py-1.5 font-semibold">📅 종일</button>
          <button type="button" onclick="applyTimePreset('clear')" class="text-xs border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 rounded-lg px-3 py-1.5">🗑️ 모두 해제</button>
        </div>

        <div class="bg-slate-50 border rounded-lg px-3 py-2 text-xs">
          <span class="text-slate-500">선택된 시간: </span>
          <span id="time-summary-list" class="font-mono text-slate-800">(없음)</span>
        </div>

        <details id="time-details" class="mt-2">
          <summary class="cursor-pointer text-sm text-indigo-600 hover:text-indigo-800 py-1 select-none">▶ 직접 선택 / 30분 단위 시간 / 사용자 정의 추가</summary>
          <div class="mt-2 border rounded-lg p-3 bg-white">
            <div class="text-xs text-slate-500 mb-1">오전</div>
            <div class="flex flex-wrap items-center gap-1.5 mb-3">
              <% MORNING_PRESETS.forEach(t => { %>
                <label class="flex items-center gap-1.5 border rounded-lg px-2.5 py-1 cursor-pointer has-[:checked]:bg-emerald-50 has-[:checked]:border-emerald-300 text-sm">
                  <input type="checkbox" name="morning_hours" value="<%= t %>" onchange="updateTimeSummary()">
                  <span><%= t %></span>
                </label>
              <% }) %>
              <div id="morning-extra" class="contents"></div>
            </div>
            <div class="text-xs text-slate-500 mb-1">오후</div>
            <div class="flex flex-wrap items-center gap-1.5 mb-3">
              <% AFTERNOON_PRESETS.forEach(t => { %>
                <label class="flex items-center gap-1.5 border rounded-lg px-2.5 py-1 cursor-pointer has-[:checked]:bg-emerald-50 has-[:checked]:border-emerald-300 text-sm">
                  <input type="checkbox" name="afternoon_hours" value="<%= t %>" onchange="updateTimeSummary()">
                  <span><%= t %></span>
                </label>
              <% }) %>
              <div id="afternoon-extra" class="contents"></div>
            </div>
            <div class="flex items-center gap-2 text-xs bg-slate-50 border rounded-lg px-3 py-2">
              <span class="text-slate-500">+ 사용자 정의:</span>
              <input id="custom-time-input" type="text" placeholder="예: 8:45" class="border rounded px-2 py-1 w-20">
              <button type="button" onclick="addCustomTime()" class="bg-indigo-600 hover:bg-indigo-700 text-white rounded px-2 py-1 text-xs">추가</button>
              <span class="text-slate-400 text-[11px]">HH:MM 형식. 12시 이전=오전, 이후=오후 그룹</span>
            </div>
          </div>
        </details>
      </div>

      <script>
        function applyTimePreset(kind) {
          document.querySelectorAll('input[name="morning_hours"], input[name="afternoon_hours"]').forEach(c => c.checked = false);
          const setChecked = (name, values) => {
            document.querySelectorAll('input[name="'+name+'"]').forEach(c => { if (values.includes(c.value)) c.checked = true; });
          };
          if (kind === 'work') { setChecked('morning_hours', ['10:00','11:00']); setChecked('afternoon_hours', ['13:00','14:00','15:00','16:00']); }
          else if (kind === 'morning') { setChecked('morning_hours', ['9:00','10:00','11:00']); }
          else if (kind === 'afternoon') { setChecked('afternoon_hours', ['13:00','14:00','15:00','16:00']); }
          else if (kind === 'allday') { setChecked('morning_hours', ['9:00','10:00','11:00']); setChecked('afternoon_hours', ['13:00','14:00','15:00','16:00']); }
          updateTimeSummary();
        }
        function updateTimeSummary() {
          const checked = [...document.querySelectorAll('input[name="morning_hours"]:checked, input[name="afternoon_hours"]:checked')]
            .map(c => c.value)
            .sort((a,b) => {
              const [ah,am]=a.split(':').map(Number), [bh,bm]=b.split(':').map(Number);
              return (ah*60+am) - (bh*60+bm);
            });
          const el = document.getElementById('time-summary-list');
          if (checked.length === 0) {
            el.textContent = '(없음 → 기본값 10:00, 14:00, 15:00 적용됨)';
            el.classList.add('text-slate-400');
          } else {
            el.textContent = checked.join(' · ');
            el.classList.remove('text-slate-400');
          }
        }
        document.addEventListener('DOMContentLoaded', updateTimeSummary);
      </script>

      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="block text-sm font-medium text-slate-700">📅 특정 날짜만 다른 시간 (선택)</label>
          <span class="text-xs text-slate-400">추가된 <span id="override-count">0</span>개</span>
        </div>

        <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-3 mb-2">
          <div class="flex flex-wrap gap-2 items-center text-sm">
            <input type="text" id="quick-override-date-text" placeholder="2026-05-23" class="border rounded px-2 py-1 text-sm w-32" inputmode="numeric"
                   onkeydown="if(event.key==='Enter'){event.preventDefault(); addQuickOverride();}">
            <input type="date" id="quick-override-date-picker" class="border rounded px-2 py-1 text-sm" onchange="document.getElementById('quick-override-date-text').value=this.value;">
            <div class="flex gap-1">
              <label class="flex items-center gap-1 border rounded px-2 py-1 cursor-pointer has-[:checked]:bg-emerald-100 has-[:checked]:border-emerald-400 text-xs">
                <input type="radio" name="quick-override-period" value="오전" checked> 오전만
              </label>
              <label class="flex items-center gap-1 border rounded px-2 py-1 cursor-pointer has-[:checked]:bg-emerald-100 has-[:checked]:border-emerald-400 text-xs">
                <input type="radio" name="quick-override-period" value="오후"> 오후만
              </label>
              <label class="flex items-center gap-1 border rounded px-2 py-1 cursor-pointer has-[:checked]:bg-emerald-100 has-[:checked]:border-emerald-400 text-xs">
                <input type="radio" name="quick-override-period" value="종일"> 종일
              </label>
            </div>
            <button type="button" onclick="addQuickOverride()" class="bg-emerald-600 hover:bg-emerald-700 text-white rounded px-3 py-1 text-xs font-semibold">+ 추가</button>
          </div>
          <p class="text-[11px] text-emerald-800 mt-2">날짜 직접 입력 (<code>2026-05-23</code>, <code>2026.5.23</code>, <code>2026/5/23</code>) 또는 달력 아이콘 클릭. 입력 후 Enter도 가능.</p>
        </div>

        <div id="override-chips" class="flex flex-wrap gap-1.5 mb-2"></div>

        <div class="bg-slate-50 border rounded-lg p-3">
          <div class="text-xs font-semibold text-slate-700 mb-2">📝 직접 입력 / 시간 지정</div>
          <textarea name="date_overrides" rows="3" class="w-full border rounded-lg px-3 py-2 font-mono text-xs" placeholder="2026-05-23 : 오전
2026-05-22 : 09:30
2026.5.26. : 13:00, 14:30" oninput="syncOverrideChipsFromText()"></textarea>
          <pre class="text-[11px] text-slate-600 m-0 mt-2 bg-white border rounded px-2 py-1.5">2026-05-23 : 오전            <span class="text-slate-400"># 5/23은 오전 시간들만</span>
2026.5.26. : 13:00, 14:30   <span class="text-slate-400"># 직접 시간 지정도 가능</span>
2026/5/27 : 9:30, 13:30     <span class="text-slate-400"># 날짜 구분자 -, ., / 다 OK</span></pre>
          <p class="text-[11px] text-slate-500 mt-1">"오전/오후/종일" 키워드는 위에서 선택한 시간들 사용. 위의 초록 박스에서 추가한 내용도 여기 자동 입력됨.</p>
        </div>
      </div>

      <script>
        function syncOverrideChipsFromText() {
          const ta = document.querySelector('textarea[name="date_overrides"]');
          const container = document.getElementById('override-chips');
          const lines = ta.value.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
          container.innerHTML = '';
          for (const line of lines) {
            const m = line.match(/^(\S+)\s*:\s*(.+)$/);
            if (!m) continue;
            const date = m[1];
            const value = m[2];
            const chip = document.createElement('div');
            chip.className = 'inline-flex items-center gap-1 bg-white border border-emerald-300 rounded-full px-2.5 py-1 text-xs';
            const d = new Date(date.replace(/\./g,'-').replace(/\//g,'-'));
            const dayKo = ['일','월','화','수','목','금','토'];
            const dateLabel = isNaN(d.getTime()) ? date : `${d.getMonth()+1}/${d.getDate()}(${dayKo[d.getDay()]})`;
            chip.innerHTML = `<span class="font-semibold text-slate-700">${dateLabel}</span><span class="text-slate-400">·</span><span class="text-emerald-700">${value}</span><button type="button" class="text-rose-400 hover:text-rose-600 ml-1" onclick="removeOverrideChip('${date.replace(/'/g,'')}')">✕</button>`;
            container.appendChild(chip);
          }
          document.getElementById('override-count').textContent = lines.length;
        }
        function removeOverrideChip(date) {
          const ta = document.querySelector('textarea[name="date_overrides"]');
          const lines = ta.value.split(/\r?\n/).map(l => l.trim()).filter(Boolean).filter(l => !l.startsWith(date));
          ta.value = lines.join('\n');
          syncOverrideChipsFromText();
        }
      </script>

      <script>
        function normalizeOverrideDate(s) {
          if (!s) return '';
          const m = String(s).replace(/\./g,'-').replace(/\//g,'-').match(/^(\d{4})-(\d{1,2})-(\d{1,2})\.?$/);
          if (!m) return '';
          return `${m[1]}-${String(m[2]).padStart(2,'0')}-${String(m[3]).padStart(2,'0')}`;
        }
        function addQuickOverride() {
          const raw = document.getElementById('quick-override-date-text').value
            || document.getElementById('quick-override-date-picker').value;
          const date = normalizeOverrideDate(raw);
          const period = document.querySelector('input[name="quick-override-period"]:checked').value;
          if (!date) { alert('날짜 형식을 확인하세요 (예: 2026-05-23)'); return; }
          const textarea = document.querySelector('textarea[name="date_overrides"]');
          const line = `${date} : ${period}`;
          const lines = textarea.value.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
          const idx = lines.findIndex(l => l.startsWith(date));
          if (idx >= 0) lines[idx] = line; else lines.push(line);
          textarea.value = lines.join('\n');
          document.getElementById('quick-override-date-text').value = '';
          document.getElementById('quick-override-date-picker').value = '';
          syncOverrideChipsFromText();
        }
        document.addEventListener('DOMContentLoaded', syncOverrideChipsFromText);
      </script>

      <script>
        function addCustomTime() {
          const inp = document.getElementById('custom-time-input');
          const v = inp.value.trim();
          const m = v.match(/^(\d{1,2}):(\d{2})$/);
          if (!m) { alert('HH:MM 형식 (예: 8:45)으로 입력해주세요.'); return; }
          const hh = parseInt(m[1]), mm = parseInt(m[2]);
          if (hh < 0 || hh > 23 || mm < 0 || mm > 59) { alert('시:분 범위 확인 (00:00 ~ 23:59)'); return; }
          const time = `${hh}:${String(mm).padStart(2,'0')}`;
          const grp = hh < 12 ? 'morning' : 'afternoon';
          const container = document.getElementById(grp + '-extra');
          if ([...container.querySelectorAll('input')].some(i => i.value === time)) { alert('이미 추가된 시간입니다.'); inp.value=''; return; }
          const label = document.createElement('label');
          label.className = 'flex items-center gap-1.5 border border-amber-400 bg-amber-50 rounded-lg px-3 py-1.5 cursor-pointer';
          label.innerHTML = `<input type="checkbox" name="${grp}_hours" value="${time}" checked><span>${time}</span><button type="button" class="text-rose-500 ml-1" onclick="this.parentElement.remove()">×</button>`;
          container.appendChild(label);
          inp.value = '';
        }
      </script>
    </section>

    <section class="bg-white border rounded-xl p-6 space-y-4">
      <h2 class="font-bold text-slate-900">3. 알림 발송 설정</h2>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">발송 채널 (위원에게 가능일정 응답 링크 보내기)</label>
        <div class="flex gap-2">
          <label class="flex items-center gap-2 border rounded-lg px-4 py-2 cursor-pointer has-[:checked]:bg-blue-50 has-[:checked]:border-blue-300">
            <input type="checkbox" name="notify_channels" value="email" checked>
            <span>📧 이메일</span>
          </label>
          <label class="flex items-center gap-2 border rounded-lg px-4 py-2 cursor-pointer has-[:checked]:bg-emerald-50 has-[:checked]:border-emerald-300">
            <input type="checkbox" name="notify_channels" value="sms" checked>
            <span>📱 SMS / MMS</span>
          </label>
        </div>
        <p class="text-xs text-slate-500 mt-1.5">SMS는 휴대전화 번호가 등록된 위원에게만 발송됩니다.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">📞 ARS 자동 전화 (SMS 발송 후 응답 없을 때)</label>
        <select name="ars_after_minutes" class="w-full border rounded-lg px-3 py-2">
          <option value="0">사용 안함</option>
          <option value="2">2분 후 (데모용)</option>
          <option value="60">1시간 후</option>
          <option value="180" selected>3시간 후</option>
          <option value="360">6시간 후</option>
          <option value="720">12시간 후</option>
          <option value="1440">24시간 후</option>
        </select>
        <p class="text-xs text-slate-500 mt-1.5">SMS 응답이 없는 위원에게 자동으로 ARS 전화가 발신됩니다. (현재는 발송 로그로 시뮬레이션)</p>
      </div>
    </section>

    <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4 text-sm">
      <div class="font-semibold text-indigo-900 mb-1">⚡ 처리 요약</div>
      <ul class="list-disc pl-5 text-indigo-900/90 text-xs space-y-1">
        <li>입력한 조건에 맞춰 후보 슬롯 6개 자동 생성</li>
        <li>내부위원 시간표 충돌 슬롯은 자동 '불가' 표시</li>
        <li>전체 위원 (<%= members.length %>명) 에게 응답 링크 발송 (이메일/SMS)</li>
        <li>SMS 응답 미회신시 ARS 자동 전화 (설정시)</li>
      </ul>
    </div>

    <div class="flex gap-2">
      <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-lg font-semibold">회의 생성 및 일정 조율 시작</button>
      <a href="/admin/committees/<%= committee.id %>" onclick="clearDraft(false)" class="px-5 py-2.5 rounded-lg border hover:bg-slate-50">취소</a>
    </div>
  </form>
</main>

<script>
const DRAFT_KEY = 'meeting_new_draft_committee_<%= committee.id %>';
const form = document.getElementById('meeting-form');

function saveDraft() {
  const data = {};
  for (const el of form.elements) {
    if (!el.name) continue;
    if (el.type === 'checkbox' || el.type === 'radio') {
      if (el.checked) {
        if (!data[el.name]) data[el.name] = [];
        data[el.name].push(el.value);
      }
    } else {
      data[el.name] = el.value;
    }
  }
  try { localStorage.setItem(DRAFT_KEY, JSON.stringify(data)); } catch(e) {}
}

function restoreDraft() {
  let raw;
  try { raw = localStorage.getItem(DRAFT_KEY); } catch(e) { return; }
  if (!raw) return;
  let data; try { data = JSON.parse(raw); } catch(e) { return; }
  let restored = false;
  for (const el of form.elements) {
    if (!el.name) continue;
    if (!(el.name in data)) continue;
    if (el.type === 'checkbox' || el.type === 'radio') {
      el.checked = data[el.name].includes(el.value);
    } else if (el.value !== data[el.name]) {
      el.value = data[el.name];
      restored = true;
    }
    if (data[el.name] && (data[el.name].length || data[el.name] !== '')) restored = true;
  }
  if (restored) document.getElementById('restored-banner').classList.remove('hidden');
}

function clearDraft(confirmFirst) {
  if (confirmFirst && !confirm('작성 내용을 모두 지우시겠습니까?')) return;
  try { localStorage.removeItem(DRAFT_KEY); } catch(e) {}
  if (confirmFirst) location.reload();
}

function goEditMembers() {
  saveDraft();
  location.href = '/admin/committees/<%= committee.id %>?from=new-meeting';
}

form.addEventListener('input', saveDraft);
form.addEventListener('change', saveDraft);
form.addEventListener('submit', () => { try { localStorage.removeItem(DRAFT_KEY); } catch(e) {} });

restoreDraft();
</script>
</body></html>
