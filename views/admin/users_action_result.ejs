<%- include('../partials/head', { pageTitle: title }) %>
<%- include('../partials/admin_nav') %>
<main class="max-w-2xl mx-auto px-6 py-8">
  <a href="/admin/users" class="text-sm text-slate-500 hover:text-slate-900">← 운영자 관리</a>
  <div class="bg-white border rounded-xl p-8 mt-3">
    <h1 class="text-xl font-bold text-slate-900 mb-3"><%= title %></h1>
    <div class="text-slate-700 leading-relaxed"><%- message %></div>
    <% if (typeof note !== 'undefined' && note) { %>
      <div class="bg-amber-50 border border-amber-200 text-amber-900 text-sm rounded-lg p-3 mt-4"><%= note %></div>
    <% } %>
    <a href="/admin/users" class="inline-block mt-6 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-semibold">목록으로</a>
  </div>
</main>
</body></html>
