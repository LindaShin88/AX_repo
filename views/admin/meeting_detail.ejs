<%- include('../partials/head', { pageTitle: meeting.title }) %>
<%- include('../partials/admin_nav') %>

<% function fmtKor(dt) {
  if (!dt) return '-';
  const d = new Date(dt);
  const day = ['일','월','화','수','목','금','토'][d.getDay()];
  const pad = n => String(n).padStart(2,'0');
  return `${d.getMonth()+1}/${d.getDate()}(${day}) ${pad(d.getHours())}:${pad(d.getMinutes())}`;
} %>

<%
  const TYPE_LABEL = { faculty: '교원', staff: '직원', student: '학생', external: '외부' };
  const TYPE_BADGE = { faculty: 'badge-blue', staff: 'badge-amber', student: 'badge-green', external: 'badge-violet' };
  const DAY_KO_M = ['일','월','화','수','목','금','토'];
  function formatKor(dt) {
    if (!dt) return '';
    const d = new Date(typeof dt === 'string' ? dt.replace(' ', 'T') : dt);
    if (isNaN(d.getTime())) return String(dt);
    const pad = n => String(n).padStart(2,'0');
    return `${d.getFullYear()}. ${d.getMonth()+1}. ${d.getDate()}.(${DAY_KO_M[d.getDay()]}) ${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }
  function formatAgendaLines(description) {
    if (!description || !description.trim()) return [];
    const CIRCLED = '①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱⑲⑳';
    const items = description.split(/\r?\n/)
      .map(s => s.trim())
      .filter(Boolean)
      .map(s => s.replace(/^[\d①-⑳]+\s*[.)]\s*/, '').replace(/^[①-⑳]\s*/, '').replace(/^[•\-·]\s*/, '').trim())
      .filter(Boolean);
    if (items.length === 0) return [];
    if (items.length === 1) return [`- 안건 : ${items[0]}`];
    const out = ['- 안건'];
    items.forEach(function(item, i){
      const marker = i < CIRCLED.length ? CIRCLED[i] : '('+(i+1)+')';
      out.push('  ' + marker + ' ' + item);
    });
    return out;
  }
  function buildAnnouncement(meeting, slot) {
    const when = formatKor(slot.start_time);
    const lines = [
      `[${meeting.committee_name}] ${meeting.title}`,
      `회의 일정이 확정되었습니다.`, ``,
      `- 일시: ${when}`,
      `- 장소: ${meeting.location || '추후 공지'}`,
    ];
    lines.push.apply(lines, formatAgendaLines(meeting.description));
    lines.push(``, `참석 부탁드립니다.`, `감사합니다.`);
    return lines.join('\n');
  }
%>
<main class="max-w-7xl mx-auto px-6 py-8">
  <a href="/admin/committees/<%= meeting.committee_id %>" class="text-sm text-slate-500 hover:text-slate-900">← <%= meeting.committee_name %></a>
  <div class="flex items-start justify-between mt-2 mb-6">
    <div>
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-2xl font-bold text-slate-900"><%= meeting.title %></h1>
        <% if (meeting.status === 'scheduling') { %><span class="badge badge-amber">일정 조율중</span>
        <% } else if (meeting.status === 'confirmed') { %><span class="badge badge-blue">일정 확정</span>
        <% } else if (meeting.status === 'completed') { %><span class="badge badge-green">완료</span><% } %>
        <form method="POST" action="/admin/meetings/<%= meeting.id %>/delete" onsubmit="return confirm('⚠️ 회의 「<%= meeting.title %>」를 삭제할까요?\n\n관련 모든 응답·서명·알림·토큰이 영구 삭제됩니다.\n되돌릴 수 없습니다.')" class="inline">
          <button type="submit" class="text-xs border border-red-200 rounded px-2 py-0.5 text-red-600 hover:bg-red-50">🗑️ 회의 삭제</button>
        </form>
      </div>
      <% if (meeting.description) { %><p class="text-sm text-slate-500 mt-1"><%= meeting.description %></p><% } %>
      <% if (confirmedSlot) { %>
        <div class="mt-2 inline-flex items-center gap-2 bg-blue-50 text-blue-900 px-3 py-1.5 rounded-lg text-sm">
          <strong>확정 일정:</strong> <%= formatKor(confirmedSlot.start_time) %>
          <% if (meeting.location) { %> · <%= meeting.location %><% } %>
        </div>
        <button type="button" onclick="openAnnouncementPopup()" class="mt-2 ml-2 inline-flex items-center gap-1.5 text-xs bg-emerald-600 hover:bg-emerald-700 text-white rounded px-3 py-1.5 font-semibold">
          📱 SMS 발송용 텍스트 복사
        </button>

        <div id="announce-backdrop" class="hidden fixed inset-0 bg-black/40 z-40" onclick="closeAnnouncementPopup()"></div>
        <div id="announce-modal" class="hidden fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-[92vw] max-w-md bg-white rounded-2xl shadow-2xl p-5">
          <div class="flex items-center justify-between mb-3">
            <h3 class="font-bold text-slate-900">📱 SMS / 카톡 발송용 텍스트</h3>
            <button type="button" onclick="closeAnnouncementPopup()" class="text-slate-400 hover:text-slate-700 text-xl">×</button>
          </div>
          <p class="text-xs text-slate-500 mb-2">아래 텍스트를 복사해서 메신저/문자에 그대로 붙여넣으면 돼요.</p>
          <pre id="announce-text" class="bg-slate-50 border rounded-lg p-3 text-sm whitespace-pre-wrap font-sans select-all"><%= buildAnnouncement(meeting, confirmedSlot) %></pre>
          <div class="flex gap-2 mt-3">
            <button type="button" id="announce-copy-btn" onclick="copyAnnouncement()" class="flex-1 inline-flex items-center justify-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg px-4 py-2 text-sm font-semibold">
              📋 클립보드에 복사
            </button>
            <button type="button" onclick="closeAnnouncementPopup()" class="border rounded-lg px-4 py-2 text-sm">닫기</button>
          </div>
        </div>
        <script>
          function openAnnouncementPopup(){ document.getElementById('announce-backdrop').classList.remove('hidden'); document.getElementById('announce-modal').classList.remove('hidden'); }
          function closeAnnouncementPopup(){ document.getElementById('announce-backdrop').classList.add('hidden'); document.getElementById('announce-modal').classList.add('hidden'); }
          function copyAnnouncement(){
            const txt = document.getElementById('announce-text').innerText;
            navigator.clipboard.writeText(txt).then(()=>{
              const b = document.getElementById('announce-copy-btn');
              const original = b.innerHTML;
              b.innerHTML = '✅ 복사됨!';
              b.classList.remove('bg-indigo-600','hover:bg-indigo-700');
              b.classList.add('bg-emerald-600');
              setTimeout(()=>{ b.innerHTML = original; b.classList.add('bg-indigo-600','hover:bg-indigo-700'); b.classList.remove('bg-emerald-600'); }, 2000);
            });
          }
        </script>
      <% } %>
      <div class="mt-2 flex flex-wrap gap-1.5 text-xs">
        <% (meeting.notify_channels || 'email,sms').split(',').forEach(ch => { %>
          <% if (ch === 'email') { %><span class="badge badge-blue">📧 이메일 발송</span><% } %>
          <% if (ch === 'sms') { %><span class="badge badge-green">📱 SMS 발송</span><% } %>
        <% }) %>
        <% if (meeting.ars_after_minutes > 0) { %>
          <span class="badge badge-amber">📞 ARS 자동전화 (응답 없으면 <%= meeting.ars_after_minutes %>분 후)</span>
        <% } %>
        <% if (meeting.schedule_constraints) { %>
          <% try { var c = JSON.parse(meeting.schedule_constraints); %>
            <span class="badge badge-gray"><%= c.window?.start %> ~ <%= c.window?.end %></span>
            <% if (c.excludedDates?.length) { %><span class="badge badge-red">제외: <%= c.excludedDates.join(', ') %></span><% } %>
            <% function fmtTimeEntry(h){ if(typeof h==='number') return h+':00'; if(h&&typeof h==='object'&&typeof h.h==='number') return h.h+':'+String(h.m||0).padStart(2,'0'); if(typeof h==='string'){var m=h.match(/^(\d{1,2})(?::(\d{2}))?$/); if(m) return m[1]+':'+(m[2]||'00');} return String(h); } %>
            <% var hours = [...(c.morningHours||[]), ...(c.afternoonHours||[])]; if (hours.length) { %><span class="badge badge-violet">시작 시간: <%= hours.map(fmtTimeEntry).join(' · ') %></span><% } %>
          <% } catch(e) {} %>
        <% } %>
      </div>
    </div>
    <div class="flex gap-2">
      <% if (meeting.status === 'scheduling') { %>
      <button type="button" onclick="openReminderPreview()" class="border bg-white hover:bg-slate-50 px-3 py-2 rounded-lg text-sm">⏰ 미응답자 리마인드</button>

      <div id="rem-backdrop" class="hidden fixed inset-0 bg-black/40 z-40" onclick="closeReminderPreview()"></div>
      <div id="rem-modal" class="hidden fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-50 w-[92vw] max-w-2xl bg-white rounded-2xl shadow-2xl p-5 max-h-[85vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-3">
          <h3 class="font-bold text-slate-900">⏰ 미응답자 리마인드 미리보기</h3>
          <button type="button" onclick="closeReminderPreview()" class="text-slate-400 hover:text-slate-700 text-xl">×</button>
        </div>
        <div id="rem-targets" class="mb-3 text-xs text-slate-600"></div>
        <form id="rem-form" method="POST" action="/admin/meetings/<%= meeting.id %>/remind" class="space-y-2">
          <div>
            <label class="text-xs text-slate-500">제목</label>
            <input name="custom_subject" id="rem-subject" class="border rounded-lg px-3 py-2 text-sm w-full mt-1">
          </div>
          <div>
            <label class="text-xs text-slate-500">본문 (수정 가능 · <code class="bg-slate-100 px-1 rounded">{이름}</code>, <code class="bg-slate-100 px-1 rounded">{링크}</code> 자동 치환)</label>
            <textarea name="custom_content" id="rem-content" rows="6" class="border rounded-lg px-3 py-2 text-sm w-full mt-1 font-mono" oninput="updateRemSample()"></textarea>
          </div>
          <div>
            <div class="text-xs text-slate-500 mb-1">📨 첫 번째 미응답 위원에게 발송될 실제 모습 (미리보기)</div>
            <pre id="rem-sample" class="bg-slate-50 border rounded-lg p-3 text-xs whitespace-pre-wrap font-sans text-slate-700"></pre>
          </div>
          <div class="flex gap-2 pt-2">
            <button type="submit" class="flex-1 bg-amber-500 hover:bg-amber-600 text-white py-2 rounded-lg text-sm font-semibold">📤 위 내용 그대로 전체 미응답자에게 발송</button>
            <button type="button" onclick="closeReminderPreview()" class="border rounded-lg px-4 py-2 text-sm">취소</button>
          </div>
        </form>
      </div>
      <script>
        let _remData = null;
        async function openReminderPreview() {
          try {
            const r = await fetch('/admin/meetings/<%= meeting.id %>/remind/preview');
            const data = await r.json();
            _remData = data;
            document.getElementById('rem-subject').value = data.subject;
            document.getElementById('rem-content').value = data.content;
            const list = (data.members || []).map(m => `<span class="inline-flex items-center gap-1 bg-amber-50 border border-amber-200 rounded-full px-2 py-0.5 mr-1 mb-1">${m.name} (${m.email || '이메일 없음'})</span>`).join('');
            document.getElementById('rem-targets').innerHTML = `<div class="font-semibold mb-1">대상 ${data.members.length}명</div>${list || '<span class="text-slate-400">미응답자 없음</span>'}`;
            updateRemSample();
            document.getElementById('rem-backdrop').classList.remove('hidden');
            document.getElementById('rem-modal').classList.remove('hidden');
          } catch (e) { alert('미리보기 로드 실패: ' + e.message); }
        }
        function updateRemSample() {
          if (!_remData) return;
          const sample = _remData.members[0];
          const content = document.getElementById('rem-content').value;
          const filled = content
            .replace(/\{이름\}/g, sample ? sample.name : '(위원)')
            .replace(/\{링크\}/g, _remData.samplePreview.match(/https?:\S+/)?.[0] || '(링크)');
          document.getElementById('rem-sample').textContent = filled;
        }
        function closeReminderPreview() {
          document.getElementById('rem-backdrop').classList.add('hidden');
          document.getElementById('rem-modal').classList.add('hidden');
        }
      </script>
      <form method="POST" action="/admin/meetings/<%= meeting.id %>/ars-now" onsubmit="return confirm('SMS 미응답 위원에게 ARS 자동 전화를 시뮬레이션 발송합니다. 진행할까요?')">
        <button class="border bg-white hover:bg-slate-50 px-3 py-2 rounded-lg text-sm">📞 ARS 즉시 발송</button>
      </form>
      <% } %>
      <a href="/admin/meetings/<%= meeting.id %>/sms-send" class="bg-white border hover:bg-slate-50 px-3 py-2 rounded-lg text-sm">📱 SMS 수동 발송</a>
      <% if (meeting.pdf_path) { %>
      <a href="/admin/meetings/<%= meeting.id %>/pdf" class="bg-emerald-600 hover:bg-emerald-700 text-white px-3 py-2 rounded-lg text-sm font-semibold">📄 PDF 다운로드</a>
      <% } %>
    </div>
  </div>

  <% const respondedSet = new Set(responses.filter(r=>!r.auto_filled).map(r=>r.member_id)); %>

  <section class="bg-white border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-bold text-slate-900">진행 단계</h2>
    </div>
    <div class="relative">
      <div class="absolute top-5 left-0 right-0 h-1 bg-slate-100 rounded"></div>
      <div class="absolute top-5 left-0 h-1 bg-gradient-to-r from-indigo-500 to-violet-600 rounded transition-all" style="width: <%= progress.progressPct %>%"></div>
      <div class="relative grid grid-cols-4 gap-2">
        <% progress.stages.forEach((s, i) => { %>
          <div class="flex flex-col items-center text-center">
            <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-white <%= s.done ? 'bg-gradient-to-br from-indigo-500 to-violet-600' : 'bg-slate-300' %>">
              <% if (s.done) { %>✓<% } else { %><%= i+1 %><% } %>
            </div>
            <div class="text-xs font-semibold mt-2 <%= s.done ? 'text-slate-900' : 'text-slate-400' %>"><%= s.label.replace(/^\d+\.\s*/, '') %></div>
            <div class="text-[10px] text-slate-500 mt-0.5"><%= s.detail %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-6">
    <div class="bg-white border rounded-xl p-4">
      <div class="text-xs text-slate-500">위원 수</div>
      <div class="text-2xl font-bold mt-1"><%= members.length %></div>
    </div>
    <div class="bg-white border rounded-xl p-4">
      <div class="text-xs text-slate-500">응답 완료</div>
      <div class="text-2xl font-bold text-emerald-600 mt-1"><%= respondedSet.size %><span class="text-sm text-slate-400 font-normal">/<%= members.length %></span></div>
    </div>
    <div class="bg-white border rounded-xl p-4">
      <div class="text-xs text-slate-500">서명 완료</div>
      <div class="text-2xl font-bold text-violet-600 mt-1"><%= signatures.length %><span class="text-sm text-slate-400 font-normal">/<%= members.length %></span></div>
    </div>
    <div class="bg-white border rounded-xl p-4">
      <div class="text-xs text-slate-500">발송 알림</div>
      <div class="text-2xl font-bold text-slate-700 mt-1"><%= notifications.length %></div>
    </div>
  </div>

  <%
    const QUORUM = meeting.quorum || 0;
    let bestQuorumSlot = null;
    let bestAvail = -1;
    slotMatrix.forEach(({ slot, availableCount }) => {
      if (availableCount > bestAvail) { bestAvail = availableCount; bestQuorumSlot = { slot, availableCount }; }
    });
    const canForceConfirm = QUORUM > 0 && bestAvail >= QUORUM;
  %>
  <% if (meeting.status === 'scheduling') { %>
  <% if (locals.actionFlag === 'remind-sent') { %>
  <div class="mb-4 bg-amber-50 border border-amber-300 text-amber-900 rounded-lg px-3 py-2 text-sm">⏰ 미응답자에게 리마인드 메일 발송 완료 (실제 발송 여부는 아래 알림 로그에서 확인)</div>
  <% } %>
  <% if (locals.actionFlag === 'force-confirmed') { %>
  <div class="mb-4 bg-blue-50 border border-blue-300 text-blue-900 rounded-lg px-3 py-2 text-sm">✅ 강제 확정 완료. 모든 위원에게 일정확정 메일 발송됨.</div>
  <% } else if (locals.actionFlag === 'confirmed') { %>
  <div class="mb-4 bg-blue-50 border border-blue-300 text-blue-900 rounded-lg px-3 py-2 text-sm">✅ 일정 확정 완료. 모든 위원에게 안내 메일 발송됨.</div>
  <% } %>

  <% if (QUORUM > 0) { %>
  <section class="mb-4 bg-gradient-to-r <%= canForceConfirm ? 'from-emerald-50 to-blue-50 border-emerald-300' : 'from-amber-50 to-rose-50 border-amber-300' %> border rounded-xl p-4">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <div>
        <div class="text-xs text-slate-500">정족수 (성원)</div>
        <div class="text-lg font-bold mt-0.5">
          최대 가능 인원 <span class="<%= canForceConfirm ? 'text-emerald-700' : 'text-amber-700' %>"><%= bestAvail %></span>
          <span class="text-slate-400 text-sm">/ 정족수 <%= QUORUM %> / 위원 전체 <%= members.length %></span>
        </div>
        <% if (canForceConfirm) { %>
          <div class="text-xs text-emerald-800 mt-1">✅ 미응답자가 있어도 가능 응답자만으로 성원 충족. 아래 버튼으로 강제 확정 가능.</div>
        <% } else { %>
          <div class="text-xs text-amber-800 mt-1">⚠️ 아직 정족수 미달 — 리마인드 후 응답을 추가로 받아야 함.</div>
        <% } %>
      </div>
      <% if (canForceConfirm && bestQuorumSlot) { %>
      <form method="POST" action="/admin/meetings/<%= meeting.id %>/confirm"
            onsubmit="return confirm('성원 충족: 미응답자 있어도 다음 일정으로 강제 확정합니다.\n\n· <%= fmtKor(bestQuorumSlot.slot.start_time) %>\n· 가능 응답 <%= bestAvail %>명 (정족수 <%= QUORUM %>)\n\n진행할까요?')">
        <input type="hidden" name="slot_id" value="<%= bestQuorumSlot.slot.id %>">
        <input type="hidden" name="force" value="1">
        <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-4 py-3 rounded-lg text-sm shadow">⚡ 성원 충족 → 강제 확정<br><span class="font-normal text-xs"><%= fmtKor(bestQuorumSlot.slot.start_time) %></span></button>
      </form>
      <% } %>
    </div>
  </section>
  <% } %>

  <section class="bg-white border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
      <h2 class="font-bold text-slate-900">📅 후보 일정별 응답 현황</h2>
      <div class="flex items-center gap-3">
        <div class="inline-flex border rounded-lg overflow-hidden text-xs">
          <button type="button" id="matrix-mode-slot" onclick="setMatrixMode('slot')" class="px-3 py-1.5 bg-indigo-600 text-white font-semibold">슬롯 = 행</button>
          <button type="button" id="matrix-mode-member" onclick="setMatrixMode('member')" class="px-3 py-1.5 bg-white hover:bg-slate-50">위원 = 행</button>
        </div>
        <span class="text-xs text-slate-500">초록=가능 / 빨강=불가 / 회색=미응답 · '시'=시간표 자동</span>
      </div>
    </div>

    <div id="matrix-slot" class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-slate-50">
            <th class="border-b border-slate-200 px-3 py-2 text-left text-xs sticky left-0 bg-slate-50">후보 일정</th>
            <% members.forEach(m => { %>
              <th class="border-b border-slate-200 px-2 py-2 text-xs text-center" style="min-width:60px;">
                <%= m.name %>
                <div class="text-[10px] text-slate-400 font-normal"><%= TYPE_LABEL[m.type] || m.type %></div>
              </th>
            <% }) %>
            <th class="border-b border-slate-200 px-3 py-2 text-xs text-center">집계</th>
            <th class="border-b border-slate-200 px-2 py-2 text-xs text-center">확정</th>
          </tr>
        </thead>
        <tbody>
          <% slotMatrix.forEach(({ slot, cells, availableCount, unavailableCount, noResp }) => { %>
            <tr class="hover:bg-slate-50">
              <td class="border-b border-slate-100 px-3 py-2 font-medium text-sm sticky left-0 bg-white">
                <%= fmtKor(slot.start_time) %>
                <span class="text-slate-400 text-xs">~ <%= fmtKor(slot.end_time).split(' ')[1] %></span>
              </td>
              <% cells.forEach(({ member, response }) => { %>
                <td class="border-b border-slate-100 px-1 py-2 text-center text-xs">
                  <% if (!response) { %>
                    <span class="badge badge-gray">·</span>
                  <% } else if (response.response === 'available') { %>
                    <span class="badge badge-green" title="<%= response.note || '' %>">O</span>
                  <% } else if (response.response === 'unavailable') { %>
                    <span class="badge badge-red" title="<%= response.note || '' %>">X<%= response.auto_filled ? '시' : '' %></span>
                  <% } %>
                </td>
              <% }) %>
              <td class="border-b border-slate-100 px-3 py-2 text-center text-xs">
                <span class="text-emerald-600 font-bold"><%= availableCount %></span>
                <span class="text-slate-300 mx-1">|</span>
                <span class="text-red-500"><%= unavailableCount %></span>
                <span class="text-slate-300 mx-1">|</span>
                <span class="text-slate-400"><%= noResp %></span>
              </td>
              <td class="border-b border-slate-100 px-2 py-2 text-center">
                <form method="POST" action="/admin/meetings/<%= meeting.id %>/confirm" onsubmit="return confirm('이 시간으로 회의를 확정하시겠습니까? 모든 위원에게 안내 메일이 발송됩니다.')">
                  <input type="hidden" name="slot_id" value="<%= slot.id %>">
                  <button class="text-xs bg-blue-600 hover:bg-blue-700 text-white px-2 py-1 rounded">확정</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div id="matrix-member" class="overflow-x-auto" style="display:none">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-slate-50">
            <th class="border-b border-slate-200 px-3 py-2 text-left text-xs sticky left-0 bg-slate-50">위원</th>
            <% slotMatrix.forEach(({ slot }) => { %>
              <th class="border-b border-slate-200 px-2 py-2 text-xs text-center" style="min-width:90px;">
                <%= fmtKor(slot.start_time) %>
              </th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% members.forEach((m, mi) => { %>
            <tr class="hover:bg-slate-50">
              <td class="border-b border-slate-100 px-3 py-2 font-medium text-sm sticky left-0 bg-white">
                <%= m.name %>
                <span class="text-[10px] text-slate-400 font-normal ml-1"><%= TYPE_LABEL[m.type] || m.type %></span>
              </td>
              <% slotMatrix.forEach(({ cells }) => {
                  const r = cells[mi] ? cells[mi].response : null; %>
                <td class="border-b border-slate-100 px-1 py-2 text-center text-xs">
                  <% if (!r) { %>
                    <span class="badge badge-gray">·</span>
                  <% } else if (r.response === 'available') { %>
                    <span class="badge badge-green" title="<%= r.note || '' %>">O</span>
                  <% } else if (r.response === 'unavailable') { %>
                    <span class="badge badge-red" title="<%= r.note || '' %>">X<%= r.auto_filled ? '시' : '' %></span>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr class="bg-emerald-50">
            <td class="border-b border-slate-200 px-3 py-2 text-xs text-slate-700 font-semibold sticky left-0 bg-emerald-50">가능 응답수</td>
            <% slotMatrix.forEach(({ availableCount }) => { %>
              <td class="border-b border-slate-200 px-2 py-2 text-center text-xs text-emerald-700 font-bold"><%= availableCount %></td>
            <% }) %>
          </tr>
          <tr class="bg-slate-50">
            <td class="px-3 py-2 text-xs text-slate-700 font-semibold sticky left-0 bg-slate-50">확정</td>
            <% slotMatrix.forEach(({ slot }) => { %>
              <td class="px-2 py-2 text-center">
                <form method="POST" action="/admin/meetings/<%= meeting.id %>/confirm" onsubmit="return confirm('이 시간으로 회의를 확정하시겠습니까? 모든 위원에게 안내 메일이 발송됩니다.')">
                  <input type="hidden" name="slot_id" value="<%= slot.id %>">
                  <button class="text-xs bg-blue-600 hover:bg-blue-700 text-white px-2 py-1 rounded">확정</button>
                </form>
              </td>
            <% }) %>
          </tr>
        </tfoot>
      </table>
    </div>

    <script>
      function setMatrixMode(mode) {
        const slotEl = document.getElementById('matrix-slot');
        const memberEl = document.getElementById('matrix-member');
        const btnSlot = document.getElementById('matrix-mode-slot');
        const btnMember = document.getElementById('matrix-mode-member');
        if (mode === 'member') {
          slotEl.style.display = 'none'; memberEl.style.display = '';
          btnSlot.className = 'px-3 py-1.5 bg-white hover:bg-slate-50';
          btnMember.className = 'px-3 py-1.5 bg-indigo-600 text-white font-semibold';
        } else {
          slotEl.style.display = ''; memberEl.style.display = 'none';
          btnSlot.className = 'px-3 py-1.5 bg-indigo-600 text-white font-semibold';
          btnMember.className = 'px-3 py-1.5 bg-white hover:bg-slate-50';
        }
        try { localStorage.setItem('matrixMode', mode); } catch (e) {}
      }
      try { const saved = localStorage.getItem('matrixMode'); if (saved === 'member') setMatrixMode('member'); } catch (e) {}
    </script>
  </section>
  <% } %>

  <% if (locals.timetableMatrix && timetableMatrix.dates.length > 0 && timetableMatrix.facultyCount > 0) { %>
  <section class="bg-white border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
      <h2 class="font-bold text-slate-900">📅 교원 시간표 가능/불가 매트릭스</h2>
      <div class="flex items-center gap-3 text-xs">
        <span class="flex items-center gap-1"><span class="inline-block w-4 h-4 rounded bg-emerald-100 border border-emerald-300"></span> 모두 가능</span>
        <span class="flex items-center gap-1"><span class="inline-block w-4 h-4 rounded bg-rose-200 border border-rose-400"></span> 수업 있음</span>
        <span class="text-slate-500">교원 <%= timetableMatrix.facultyCount %>명 · <%= timetableMatrix.windowStart %> ~ <%= timetableMatrix.windowEnd %></span>
      </div>
    </div>
    <p class="text-xs text-slate-500 mb-3">셀에 마우스 올리면 누가 어떤 수업인지 표시됩니다. (평일만, 9:00~17:30, 30분 단위)</p>

    <div class="overflow-x-auto">
      <table class="border-collapse text-xs">
        <thead>
          <tr>
            <th class="border border-slate-200 bg-slate-50 px-2 py-1 sticky left-0 z-10 text-slate-500 font-normal">시간 \ 날짜</th>
            <% timetableMatrix.dates.forEach(d => { %>
              <th class="border border-slate-200 bg-slate-50 px-2 py-1 text-slate-700 font-semibold whitespace-nowrap">
                <%= d.mmdd %><br><span class="text-[10px] font-normal text-slate-500">(<%= d.dayKo %>)</span>
              </th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% timetableMatrix.rows.forEach(row => { %>
            <tr>
              <td class="border border-slate-200 bg-slate-50 px-2 py-0.5 sticky left-0 z-10 text-slate-600 font-mono text-right whitespace-nowrap">
                <%= row.slot.label %>
              </td>
              <% row.cells.forEach(cell => { %>
                <% if (cell.busy.length > 0) { %>
                  <td class="border border-rose-300 bg-rose-200 hover:bg-rose-300 cursor-help" style="min-width:54px; height:22px;"
                      title="수업 있음 — <%= cell.busy.map(b => b.name + ': ' + b.title).join(', ') %>">
                    <span class="block text-center text-[10px] text-rose-900 font-semibold leading-none">×<%= cell.busy.length %></span>
                  </td>
                <% } else { %>
                  <td class="border border-emerald-200 bg-emerald-100 hover:bg-emerald-200" style="min-width:54px; height:22px;" title="모든 교원 가능"></td>
                <% } %>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <section class="bg-white border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-bold text-slate-900">👥 위원별 응답 링크</h2>
        <% if (!locals.smtpConfigured) { %>
        <a href="/admin/settings/smtp" class="text-xs bg-amber-100 text-amber-900 border border-amber-300 rounded px-2 py-1">⚠️ SMTP 미설정 — 자동 메일 발송 불가</a>
        <% } else { %>
        <span class="text-xs text-emerald-700">✅ 메일 자동 발송 활성</span>
        <% } %>
      </div>
      <p class="text-xs text-slate-500 mb-3">아래 링크를 복사해서 직접 SMS/카톡으로 보내실 수 있어요. 이메일은 위원 이메일로 자동 발송 (SMTP 설정 시).</p>
      <div class="space-y-2 text-sm">
        <% members.forEach(m => { %>
          <% const t = tokens.find(tt => tt.member_id === m.id && tt.purpose === 'availability'); %>
          <% const responded = respondedSet.has(m.id); %>
          <div class="flex items-center justify-between border-b last:border-b-0 py-2">
            <div>
              <span class="font-medium"><%= m.name %></span>
              <span class="text-xs text-slate-500 ml-2"><%= [m.affiliation, m.role].filter(Boolean).join(' / ') %></span>
              <span class="badge <%= TYPE_BADGE[m.type] || 'badge-violet' %> ml-1"><%= TYPE_LABEL[m.type] || m.type %></span>
            </div>
            <div class="flex items-center gap-2">
              <% if (responded) { %><span class="badge badge-green">응답완료</span>
              <% } else { %><span class="badge badge-gray">대기중</span><% } %>
              <% if (t) { %>
              <button onclick="navigator.clipboard.writeText('<%= baseUrl %>/avail/<%= t.token %>'); this.textContent='✓ 복사됨'" class="text-xs border rounded px-2 py-1 hover:bg-slate-50">링크 복사</button>
              <a href="/avail/<%= t.token %>" target="_blank" class="text-xs border rounded px-2 py-1 hover:bg-slate-50">↗ 열기</a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="bg-white border rounded-xl p-5">
      <h2 class="font-bold text-slate-900 mb-3">📋 내부 위원 시간표 (자동 수집)</h2>
      <div class="space-y-2">
      <% members.filter(m => m.type === 'faculty' && m.sabun).forEach(m => { %>
        <details class="border rounded-lg">
          <summary class="px-3 py-2 cursor-pointer text-sm font-medium hover:bg-slate-50"><%= m.name %> <span class="text-xs text-slate-500">#<%= m.sabun %></span></summary>
          <div class="p-3 border-t">
            <a href="<%= getTimetableImageUrl(m.sabun) %>" target="_blank" class="text-xs text-indigo-600 hover:underline">↗ 한성대 공식 시간표 보기</a>
          </div>
        </details>
      <% }) %>
      <% if (members.filter(m => m.type === 'faculty' && m.sabun).length === 0) { %>
        <p class="text-sm text-slate-500 text-center py-4">사번이 등록된 내부 위원이 없습니다.</p>
      <% } %>
      </div>
    </section>
  </div>

  <% if (meeting.status === 'confirmed' || meeting.status === 'completed') { %>
  <section class="bg-white border rounded-xl p-5 mb-6">
    <h2 class="font-bold text-slate-900 mb-3">📝 회의록 및 외부위원 서명</h2>

    <% if (locals.actionFlag === 'minutes-uploaded') { %>
      <div class="mb-3 bg-emerald-50 border border-emerald-300 text-emerald-900 rounded-lg px-3 py-2 text-sm">✅ 회의록 파일이 업로드되었습니다.</div>
    <% } else if (locals.actionFlag === 'minutes-deleted') { %>
      <div class="mb-3 bg-slate-50 border border-slate-300 text-slate-700 rounded-lg px-3 py-2 text-sm">🗑️ 업로드된 회의록을 삭제했습니다.</div>
    <% } else if (locals.actionFlag === 'minutes-upload-err') { %>
      <div class="mb-3 bg-rose-50 border border-rose-300 text-rose-900 rounded-lg px-3 py-2 text-sm">⚠️ 업로드 실패: <%= locals.actionMsg || '알 수 없는 오류' %></div>
    <% } else if (locals.actionFlag === 'external-signatures-sent') { %>
      <div class="mb-3 bg-violet-50 border border-violet-300 text-violet-900 rounded-lg px-3 py-2 text-sm">📨 외부위원 <%= locals.actionCount || 0 %>명에게 서명 요청을 발송했습니다.</div>
    <% } else if (locals.actionFlag === 'external-reminded') { %>
      <div class="mb-3 bg-amber-50 border border-amber-300 text-amber-900 rounded-lg px-3 py-2 text-sm">⏰ 미서명 외부위원 <%= locals.actionCount || 0 %>명에게 리마인드를 보냈습니다.</div>
    <% } else if (locals.actionFlag === 'no-pending-external') { %>
      <div class="mb-3 bg-emerald-50 border border-emerald-300 text-emerald-900 rounded-lg px-3 py-2 text-sm">✅ 모든 외부위원이 이미 서명을 완료했어요!</div>
    <% } else if (locals.actionFlag === 'no-external') { %>
      <div class="mb-3 bg-amber-50 border border-amber-300 text-amber-900 rounded-lg px-3 py-2 text-sm">⚠️ 이 위원회에 외부위원이 없습니다.</div>
    <% } %>

    <div class="mb-5 border border-slate-200 rounded-xl p-4 bg-slate-50">
      <div class="flex items-center justify-between mb-2">
        <h3 class="font-semibold text-slate-900 text-sm">① 회의록 파일 업로드 (PDF 또는 한글)</h3>
        <span class="text-xs text-slate-500">최대 30MB</span>
      </div>

      <% if (meeting.uploaded_minutes_path) { %>
        <div class="flex items-center justify-between bg-white border rounded-lg px-3 py-2 mb-2">
          <div class="text-sm">
            <span class="font-medium">📎 <%= meeting.uploaded_minutes_original_name %></span>
            <span class="text-xs text-slate-500 ml-2">업로드: <%= meeting.uploaded_minutes_uploaded_at %></span>
          </div>
          <div class="flex gap-2">
            <a href="/admin/meetings/<%= meeting.id %>/uploaded-minutes" class="text-xs border bg-white rounded px-2 py-1 hover:bg-slate-50">⬇ 다운로드</a>
            <form method="POST" action="/admin/meetings/<%= meeting.id %>/minutes-delete" onsubmit="return confirm('업로드된 회의록을 삭제할까요?')">
              <button class="text-xs border bg-white rounded px-2 py-1 hover:bg-rose-50 text-rose-600">🗑 삭제</button>
            </form>
          </div>
        </div>
      <% } %>

      <form method="POST" action="/admin/meetings/<%= meeting.id %>/minutes-upload" enctype="multipart/form-data" class="flex items-center gap-2">
        <input type="file" name="minutes_file" accept=".pdf,.hwp,.hwpx" required class="text-sm flex-1">
        <button class="bg-slate-900 hover:bg-slate-700 text-white px-3 py-2 rounded-lg text-sm font-semibold whitespace-nowrap">
          <%= meeting.uploaded_minutes_path ? '📤 새 파일로 교체' : '📤 업로드' %>
        </button>
      </form>
      <p class="text-xs text-slate-500 mt-2">※ PDF로 올리시는 것을 권장합니다. 한글(.hwp/.hwpx)도 업로드/다운로드 가능합니다.</p>
    </div>

    <% const externals = members.filter(m => m.type === 'external'); %>
    <% const externalSigned = externals.filter(m => signatures.find(s => s.member_id === m.id)).length; %>
    <% const externalPct = externals.length > 0 ? Math.round(externalSigned * 100 / externals.length) : 0; %>
    <% const allExternalsSigned = externals.length > 0 && externalSigned === externals.length; %>

    <div class="mb-4 border border-slate-200 rounded-xl p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="font-semibold text-slate-900 text-sm">② 외부위원 서명 링크 발송</h3>
        <div class="flex items-center gap-2">
          <span class="text-xs text-slate-500">외부위원 <%= externals.length %>명</span>
          <% if (externals.length > 0) { %>
            <label class="flex items-center gap-1 text-xs text-slate-500 cursor-pointer">
              <input type="checkbox" id="auto-refresh-toggle" onchange="toggleAutoRefresh(this.checked)">
              <span>10초마다 자동 새로고침</span>
            </label>
          <% } %>
        </div>
      </div>

      <% if (externals.length > 0) { %>
        <div class="mb-3">
          <div class="flex items-center justify-between text-xs mb-1">
            <span class="font-semibold text-slate-700">실시간 서명 현황</span>
            <span class="text-slate-600"><strong class="<%= allExternalsSigned ? 'text-emerald-700' : 'text-violet-700' %>"><%= externalSigned %></strong> / <%= externals.length %>명 서명 완료 (<%= externalPct %>%)</span>
          </div>
          <div class="w-full bg-slate-100 rounded-full h-2.5 overflow-hidden">
            <div class="h-2.5 rounded-full transition-all <%= allExternalsSigned ? 'bg-gradient-to-r from-emerald-400 to-emerald-600' : 'bg-gradient-to-r from-violet-400 to-violet-600' %>"
                 style="width: <%= externalPct %>%"></div>
          </div>
        </div>
      <% } %>

      <% if (externals.length === 0) { %>
        <p class="text-sm text-slate-500 py-2">이 위원회에 외부위원이 없습니다.</p>
      <% } else { %>
        <% const pendingExternals = externals.filter(m => !signatures.find(s => s.member_id === m.id)); %>
        <div class="flex gap-2 mb-3 items-center flex-wrap">
          <form method="POST" action="/admin/meetings/<%= meeting.id %>/request-external-signatures">
            <button class="bg-violet-600 hover:bg-violet-700 text-white px-4 py-2 rounded-lg text-sm font-semibold">📨 외부위원 전체에게 서명 요청 메일 발송</button>
          </form>
          <% if (pendingExternals.length > 0) { %>
            <form method="POST" action="/admin/meetings/<%= meeting.id %>/remind-external-signatures"
                  onsubmit="return confirm('아직 서명하지 않은 외부위원 <%= pendingExternals.length %>명에게 리마인드 메일을 보냅니다. 진행할까요?')">
              <button class="bg-amber-500 hover:bg-amber-600 text-white px-4 py-2 rounded-lg text-sm font-semibold">
                ⏰ 미서명자 <%= pendingExternals.length %>명에게 리마인드
              </button>
            </form>
          <% } %>
          <% if (!locals.smtpConfigured) { %>
            <a href="/admin/settings/smtp" class="text-xs bg-amber-100 text-amber-900 border border-amber-300 rounded px-2 py-1">⚠️ SMTP 미설정 — 메일 자동 발송 불가</a>
          <% } %>
          <% if (!meeting.uploaded_minutes_path) { %>
            <span class="text-xs bg-amber-50 text-amber-800 border border-amber-200 rounded px-2 py-1">💡 회의록 파일을 먼저 업로드하면 메일에 다운로드 링크가 포함됩니다.</span>
          <% } %>
        </div>

        <table class="w-full text-sm">
          <thead class="text-xs text-slate-500 border-b">
            <tr>
              <th class="py-2 text-left">외부위원</th>
              <th class="text-left">상태</th>
              <th class="text-left">서명 시각</th>
              <th class="text-left">서명 링크</th>
            </tr>
          </thead>
          <tbody>
            <% externals.forEach(m => { %>
              <% const sig = signatures.find(s => s.member_id === m.id); %>
              <% const t = tokens.find(tt => tt.member_id === m.id && tt.purpose === 'signature'); %>
              <tr class="border-b last:border-b-0">
                <td class="py-2">
                  <div class="font-medium"><%= m.name %></div>
                  <div class="text-xs text-slate-500"><%= [m.affiliation, m.role].filter(Boolean).join(' / ') %></div>
                </td>
                <td>
                  <% if (sig) { %><span class="badge badge-green">서명완료</span>
                  <% } else { %><span class="badge badge-gray">대기중</span><% } %>
                </td>
                <td class="text-xs text-slate-500"><%= sig ? sig.signed_at : '-' %></td>
                <td>
                  <% if (t) { %>
                    <div class="flex gap-1 flex-wrap items-center">
                      <input type="text" readonly value="<%= baseUrl %>/sign/<%= t.token %>"
                             onclick="this.select()"
                             class="text-xs border rounded px-2 py-1 bg-slate-50 w-64 font-mono">
                      <button onclick="navigator.clipboard.writeText('<%= baseUrl %>/sign/<%= t.token %>'); this.textContent='✓ 복사됨'; setTimeout(()=>this.textContent='📋 복사',1500)"
                              class="text-xs border rounded px-2 py-1 hover:bg-slate-50">📋 복사</button>
                      <a href="/sign/<%= t.token %>" target="_blank" class="text-xs border rounded px-2 py-1 hover:bg-slate-50">↗ 미리보기</a>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-slate-400">위 버튼으로 발송하면 링크 생성</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <% if (externals.length > 0) { %>
    <div class="mb-4 border border-slate-200 rounded-xl p-4 <%= allExternalsSigned ? 'bg-gradient-to-br from-emerald-50 to-blue-50' : 'bg-slate-50' %>">
      <div class="flex items-center justify-between mb-2 flex-wrap gap-2">
        <h3 class="font-semibold text-slate-900 text-sm">③ 최종 회의록 PDF (서명본)</h3>
        <% if (locals.actionFlag === 'final-pdf-generated') { %>
          <span class="text-xs text-emerald-700">✅ 방금 생성됨</span>
        <% } else if (locals.actionFlag === 'final-pdf-err') { %>
          <span class="text-xs text-rose-700">⚠️ 생성 실패: <%= locals.actionMsg %></span>
        <% } %>
      </div>

      <% if (allExternalsSigned) { %>
        <p class="text-sm text-emerald-900 mb-3">🎉 모든 외부위원 서명 완료! 업로드한 회의록 뒤에 서명 페이지가 자동으로 합쳐졌어요.</p>
      <% } else if (externalSigned > 0) { %>
        <p class="text-sm text-slate-700 mb-3">현재까지 서명된 <%= externalSigned %>명의 서명만 들어간 중간 PDF를 만들 수 있어요. 전원 완료 후 자동 재생성됩니다.</p>
      <% } else { %>
        <p class="text-sm text-slate-500 mb-3">아직 서명한 외부위원이 없어요. 첫 서명이 들어오면 PDF를 만들 수 있어요.</p>
      <% } %>

      <div class="flex gap-2 flex-wrap items-center">
        <% if (meeting.final_pdf_path) { %>
          <a href="/admin/meetings/<%= meeting.id %>/final-pdf"
             class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg text-sm font-semibold inline-flex items-center gap-1.5">
            📄 최종 PDF 다운로드
          </a>
          <a href="/admin/meetings/<%= meeting.id %>/final-pdf" target="_blank"
             class="border bg-white hover:bg-slate-50 px-3 py-2 rounded-lg text-sm">↗ 새 창으로 미리보기</a>
          <span class="text-xs text-slate-500">생성: <%= meeting.final_pdf_generated_at %></span>
        <% } %>
        <% if (externalSigned > 0) { %>
          <form method="POST" action="/admin/meetings/<%= meeting.id %>/generate-final-pdf">
            <button class="border bg-white hover:bg-slate-50 px-3 py-2 rounded-lg text-sm font-semibold"
                    title="<%= meeting.final_pdf_path ? '서명자가 추가되었거나 서명을 다시 받은 경우, 지금 서명된 모든 외부위원 기준으로 PDF를 새로 만들어요. 이전 PDF는 대체됩니다.' : '지금까지 서명한 외부위원의 서명 페이지를 회의록 뒤에 붙여 최종 PDF를 만듭니다.' %>">
              🔄 <%= meeting.final_pdf_path ? '다시 생성' : 'PDF 만들기' %> (현재 서명 기준)
            </button>
          </form>
          <% if (meeting.final_pdf_path) { %>
          <span class="text-[11px] text-slate-400" title="서명자가 추가되었거나 다시 받은 경우 클릭. 현재 서명된 모든 외부위원 기준으로 PDF 재생성">ℹ️ 서명자 추가 후 다시 받은 경우 클릭</span>
          <% } %>
        <% } %>
        <% if (meeting.uploaded_minutes_path && meeting.uploaded_minutes_original_name && /\.hwpx?$/i.test(meeting.uploaded_minutes_original_name)) { %>
          <span class="text-xs bg-amber-100 text-amber-900 border border-amber-300 rounded px-2 py-1">⚠️ 한글(.hwp) 업로드: 최종 PDF는 "외부위원 서명 페이지만" 별도 PDF로 생성됩니다.</span>
        <% } %>
      </div>
    </div>
    <% } %>

    <script>
      let autoRefreshTimer = null;
      function toggleAutoRefresh(on) {
        if (autoRefreshTimer) { clearInterval(autoRefreshTimer); autoRefreshTimer = null; }
        if (on) {
          autoRefreshTimer = setInterval(() => location.reload(), 10000);
          try { sessionStorage.setItem('meeting_auto_refresh_<%= meeting.id %>', '1'); } catch(e) {}
        } else {
          try { sessionStorage.removeItem('meeting_auto_refresh_<%= meeting.id %>'); } catch(e) {}
        }
      }
      document.addEventListener('DOMContentLoaded', () => {
        try {
          if (sessionStorage.getItem('meeting_auto_refresh_<%= meeting.id %>') === '1') {
            const cb = document.getElementById('auto-refresh-toggle');
            if (cb) { cb.checked = true; toggleAutoRefresh(true); }
          }
        } catch(e) {}
      });
    </script>

    <details class="border border-slate-200 rounded-xl p-4 text-sm bg-slate-50">
      <summary class="cursor-pointer text-slate-600 hover:text-slate-900">▾ (참고) 기존 방식 — 텍스트 회의록 + PDF 생성 + 전체 위원 서명</summary>
      <div class="mt-3">
        <form method="POST" action="/admin/meetings/<%= meeting.id %>/minutes" class="mb-3">
          <textarea name="minutes_text" rows="4" class="w-full border rounded-lg px-3 py-2 text-sm font-mono" placeholder="(선택) 회의록 텍스트"><%= meeting.minutes_text || '' %></textarea>
          <button class="mt-2 bg-slate-700 text-white px-3 py-1.5 rounded text-xs">텍스트 저장</button>
        </form>
        <div class="flex gap-2">
          <form method="POST" action="/admin/meetings/<%= meeting.id %>/request-signatures">
            <button class="bg-violet-500 hover:bg-violet-600 text-white px-3 py-1.5 rounded text-xs">전체 위원 서명 요청</button>
          </form>
          <form method="POST" action="/admin/meetings/<%= meeting.id %>/generate-pdf">
            <button class="bg-emerald-500 hover:bg-emerald-600 text-white px-3 py-1.5 rounded text-xs">자동 PDF 생성</button>
          </form>
          <% if (meeting.pdf_path) { %>
            <a href="/admin/meetings/<%= meeting.id %>/pdf" class="bg-slate-200 hover:bg-slate-300 px-3 py-1.5 rounded text-xs">📄 자동생성 PDF 다운로드</a>
          <% } %>
        </div>
      </div>
    </details>
  </section>
  <% } %>

  <section class="bg-white border rounded-xl p-5">
    <h2 class="font-bold text-slate-900 mb-3">📨 알림 발송 로그</h2>
    <div class="space-y-2 max-h-96 overflow-y-auto">
      <% notifications.forEach(n => { %>
        <div class="border rounded-lg p-3">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2 text-sm">
              <% const typeBadge = {
                availability_request: ['badge-blue','일정 요청'],
                reminder: ['badge-amber','리마인드'],
                meeting_confirmed: ['badge-green','일정 확정'],
                signature_request: ['badge-violet','서명 요청'],
                signature_reminder: ['badge-amber','✍️ 서명 리마인드'],
                ars_call: ['badge-red','📞 ARS 전화']
              }[n.type] || ['badge-gray', n.type]; %>
              <span class="badge <%= typeBadge[0] %>"><%= typeBadge[1] %></span>
              <span class="font-medium"><%= n.member_name || '전체' %></span>
              <span class="text-xs text-slate-400">[<%= n.channel %>]</span>
            </div>
            <span class="text-xs text-slate-400"><%= n.sent_at %></span>
          </div>
          <div class="text-xs text-slate-700 font-medium"><%= n.subject %></div>
          <pre class="text-xs text-slate-500 mt-1 whitespace-pre-wrap font-sans"><%= n.content %></pre>
        </div>
      <% }) %>
      <% if (notifications.length === 0) { %><p class="text-sm text-slate-500 text-center py-4">알림 이력이 없습니다.</p><% } %>
    </div>
  </section>
</main>
</body></html>
